{
	"name": "fin-track",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "vite preview",
		"build-only": "vite build",
		"type-check": "vue-tsc --build --force",
		"lint": "eslint . --fix",
		"format": "prettier --write src/",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepare": "husky"
	},
	"eslintConfig": {
		"extends": [
			"prettier"
		],
		"plugins": [
			"prettier"
		]
	},
	"dependencies": {
		"@vueuse/core": "^14.3.0",
		"cors": "^2.8.5",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"express": "^4.21.1",
		"pinia": "^3.0.4",
		"uuid": "^11.0.3",
		"vue": "^3.5.12",
		"vue-router": "^4.6.4",
		"workbox-window": "^7.4.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@tsconfig/node22": "^22.0.0",
		"@types/node": "^22.9.0",
		"@vitejs/plugin-vue": "^5.1.4",
		"@vitest/coverage-v8": "^4.1.5",
		"@vue/eslint-config-prettier": "^10.1.0",
		"@vue/eslint-config-typescript": "^14.1.3",
		"@vue/test-utils": "^2.4.10",
		"@vue/tsconfig": "^0.5.1",
		"eslint": "^9.14.0",
		"eslint-plugin-vue": "^9.30.0",
		"husky": "^9.1.7",
		"jsdom": "^27.0.1",
		"lint-staged": "^15.5.2",
		"msw": "^2.14.3",
		"nodemon": "^3.1.7",
		"npm-run-all2": "^7.0.1",
		"prettier": "^3.3.3",
		"sass-embedded": "^1.81.0",
		"typescript": "~5.6.3",
		"vite": "^5.4.10",
		"vite-plugin-pwa": "^1.3.0",
		"vite-plugin-vue-devtools": "^7.5.4",
		"vitest": "^4.1.5",
		"vue-tsc": "^2.1.10"
	},
	"lint-staged": {
		"*.{ts,vue}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{scss,md,json,html,yml,yaml}": [
			"prettier --write"
		]
	}
}
